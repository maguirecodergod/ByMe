@page "/"
@inherits BlazorBaseComponent
@inject LayoutService LayoutService
@inject IStringLocalizer<Home> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="home-page">
    <section class="welcome-section">
        <div class="welcome-badge">
            <i class="bi bi-stars"></i>
            <span>@L["WelcomeBack"]</span>
        </div>
        <h1 class="welcome-title">@L["PlatformName"]</h1>
        <p class="welcome-subtitle">@L["PlatformSubtitle"]</p>
    </section>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">@L["TotalUsers"]</span>
                <div class="stat-icon stat-icon--primary">
                    <i class="bi bi-people" style="font-size: 1.25rem;"></i>
                </div>
            </div>
            <div class="stat-value">2,847</div>
            <div class="stat-change stat-change--up">
                <i class="bi bi-graph-up"></i>
                <span>@string.Format(L["ChangeFromLastMonth"], "+12.5")</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">@L["Revenue"]</span>
                <div class="stat-icon stat-icon--success">
                    <i class="bi bi-currency-dollar" style="font-size: 1.25rem;"></i>
                </div>
            </div>
            <div class="stat-value">$48,592</div>
            <div class="stat-change stat-change--up">
                <i class="bi bi-graph-up"></i>
                <span>@string.Format(L["ChangeFromLastMonth"], "+8.2")</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">@L["ActiveSessions"]</span>
                <div class="stat-icon stat-icon--accent">
                    <i class="bi bi-activity" style="font-size: 1.25rem;"></i>
                </div>
            </div>
            <div class="stat-value">1,024</div>
            <div class="stat-change stat-change--neutral">
                <span>@L["SameAsYesterday"]</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">@L["Uptime"]</span>
                <div class="stat-icon stat-icon--warning">
                    <i class="bi bi-shield-check" style="font-size: 1.25rem;"></i>
                </div>
            </div>
            <div class="stat-value">99.98%</div>
            <div class="stat-change stat-change--up">
                <i class="bi bi-graph-up"></i>
                <span>@string.Format(L["ChangeThisWeek"], "+0.03")</span>
            </div>
        </div>
    </div>

    <div class="content-grid">
        <div class="card-panel">
            <div class="card-panel-header">
                <h2 class="card-panel-title">@L["QuickActions"]</h2>
                <span class="card-panel-badge">@string.Format(L["ActionsAvailable"], 3)</span>
            </div>
            <div class="action-list">
                <a href="counter" class="action-item">
                    <div class="action-icon">
                        <i class="bi bi-calculator"></i>
                    </div>
                    <div class="action-content">
                        <span class="action-title">@L["CounterDemo"]</span>
                        <span class="action-desc">@L["CounterDemoDesc"]</span>
                    </div>
                    <i class="bi bi-chevron-right action-arrow"></i>
                </a>
                <a href="weather" class="action-item">
                    <div class="action-icon">
                        <i class="bi bi-cloud-sun"></i>
                    </div>
                    <div class="action-content">
                        <span class="action-title">@L["WeatherForecast"]</span>
                        <span class="action-desc">@L["WeatherForecastDesc"]</span>
                    </div>
                    <i class="bi bi-chevron-right action-arrow"></i>
                </a>
                <div class="action-item action-item--disabled">
                    <div class="action-icon">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <div class="action-content">
                        <span class="action-title">@L["AdminPanel"]</span>
                        <span class="action-desc">@L["AdminPanelDesc"]</span>
                    </div>
                    <span class="action-badge">@L["Soon"]</span>
                </div>
            </div>
        </div>

        <div class="card-panel">
            <div class="card-panel-header">
                <h2 class="card-panel-title">@L["SystemStatus"]</h2>
                <span class="status-dot status-dot--online"></span>
            </div>
            <div class="status-list">
                <div class="status-item">
                    <span class="status-name">API Gateway</span>
                    <span class="status-tag status-tag--operational">@L["Operational"]</span>
                </div>
                <div class="status-item">
                    <span class="status-name">Account Service</span>
                    <span class="status-tag status-tag--operational">@L["Operational"]</span>
                </div>
                <div class="status-item">
                    <span class="status-name">Blazor Frontend</span>
                    <span class="status-tag status-tag--operational">@L["Operational"]</span>
                </div>
                <div class="status-item">
                    <span class="status-name">Database Cluster</span>
                    <span class="status-tag status-tag--maintenance">@L["Maintenance"]</span>
                </div>
            </div>
            <div class="status-footer">
                <span>@string.Format(L["LastChecked"], 2)</span>
            </div>
        </div>
    </div>
</div>

<style>
    .home-page {
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
    }

    /* Welcome */
    .welcome-section {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .welcome-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-1) var(--space-3);
        background-color: var(--color-primary-subtle);
        color: var(--color-primary);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: 500;
        width: fit-content;
    }

    .welcome-title {
        font-size: var(--text-3xl);
        font-weight: 700;
        color: var(--color-text);
        letter-spacing: var(--tracking-tight);
        margin: 0;
    }

    .welcome-subtitle {
        font-size: var(--text-md);
        color: var(--color-text-secondary);
        line-height: var(--leading-relaxed);
        max-width: 36rem;
        margin: 0;
    }

    /* Stats */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
        gap: var(--space-4);
    }

    .stat-card {
        background-color: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--card-border-radius);
        padding: var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        transition: var(--card-transition);
    }

    .stat-card:hover {
        box-shadow: var(--card-shadow-hover);
        border-color: var(--color-border-strong);
    }

    .stat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .stat-label {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        font-weight: 450;
    }

    .stat-icon {
        width: 2.25rem;
        height: 2.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-md);
    }

    .stat-icon--primary {
        background-color: var(--color-primary-subtle);
        color: var(--color-primary);
    }

    .stat-icon--success {
        background-color: var(--color-success-subtle);
        color: var(--color-success);
    }

    .stat-icon--accent {
        background-color: var(--color-accent-subtle);
        color: var(--color-accent);
    }

    .stat-icon--warning {
        background-color: var(--color-warning-subtle);
        color: var(--color-warning);
    }

    .stat-value {
        font-size: var(--text-2xl);
        font-weight: 700;
        color: var(--color-text);
        letter-spacing: var(--tracking-tight);
    }

    .stat-change {
        display: flex;
        align-items: center;
        gap: var(--space-1);
        font-size: var(--text-xs);
        font-weight: 450;
    }

    .stat-change--up { color: var(--color-success); }
    .stat-change--down { color: var(--color-danger); }
    .stat-change--neutral { color: var(--color-text-muted); }

    /* Content grid */
    .content-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
        gap: var(--space-4);
    }

    .card-panel {
        background-color: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: var(--card-border-radius);
        overflow: hidden;
    }

    .card-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-5) var(--space-5) var(--space-3);
    }

    .card-panel-title {
        font-size: var(--text-base);
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
    }

    .card-panel-badge {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        background: var(--color-surface);
        padding: var(--space-1) var(--space-2);
        border-radius: var(--radius-full);
    }

    /* Actions */
    .action-list {
        display: flex;
        flex-direction: column;
    }

    .action-item {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-3) var(--space-5);
        text-decoration: none;
        color: var(--color-text);
        transition: background-color var(--duration-base) var(--ease-default);
        cursor: pointer;
        border-bottom: 1px solid var(--color-divider);
    }

    .action-item:last-child {
        border-bottom: none;
    }

    .action-item:hover {
        background-color: var(--color-surface-hover);
        color: var(--color-text);
    }

    .action-item--disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .action-icon {
        width: 2.25rem;
        height: 2.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-surface);
        border-radius: var(--radius-md);
        color: var(--color-text-secondary);
        flex-shrink: 0;
    }

    .action-content {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
    }

    .action-title {
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--color-text);
    }

    .action-desc {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
    }

    .action-arrow {
        color: var(--color-text-muted);
        flex-shrink: 0;
        transition: transform var(--duration-base) var(--ease-default);
    }

    .action-item:hover .action-arrow {
        transform: translateX(2px);
        color: var(--color-text-secondary);
    }

    .action-badge {
        font-size: var(--text-xs);
        font-weight: 500;
        color: var(--color-warning);
        background: var(--color-warning-subtle);
        padding: var(--space-1) var(--space-2);
        border-radius: var(--radius-full);
    }

    /* Status */
    .status-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: var(--radius-full);
    }

    .status-dot--online {
        background-color: var(--color-success);
        box-shadow: 0 0 0 3px var(--color-success-subtle);
    }

    .status-list {
        display: flex;
        flex-direction: column;
    }

    .status-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3) var(--space-5);
        border-bottom: 1px solid var(--color-divider);
    }

    .status-item:last-child {
        border-bottom: none;
    }

    .status-name {
        font-size: var(--text-sm);
        color: var(--color-text);
    }

    .status-tag {
        font-size: var(--text-xs);
        font-weight: 500;
        padding: var(--space-1) var(--space-2);
        border-radius: var(--radius-full);
    }

    .status-tag--operational {
        color: var(--color-success);
        background: var(--color-success-subtle);
    }

    .status-tag--maintenance {
        color: var(--color-warning);
        background: var(--color-warning-subtle);
    }

    .status-tag--down {
        color: var(--color-danger);
        background: var(--color-danger-subtle);
    }

    .status-footer {
        padding: var(--space-3) var(--space-5);
        border-top: 1px solid var(--color-divider);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
    }
</style>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        LayoutService.SetPageHeader("Dashboard", new List<BreadcrumbItem>
        {
            new BreadcrumbItem { Label = "Dashboard", IsActive = true }
        });
    }
}
