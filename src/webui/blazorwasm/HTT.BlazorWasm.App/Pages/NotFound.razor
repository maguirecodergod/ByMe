@page "/not-found"
@layout MainLayout

<PageTitle>Not Found — HTT Platform</PageTitle>

<div class="not-found-page">
    <div class="not-found-icon">
        <i class="bi bi-emoji-frown" style="font-size: 3rem;"></i>
    </div>
    <h1 class="not-found-code">404</h1>
    <h3 class="not-found-title">Page not found</h3>
    <p class="not-found-desc">Sorry, the content you are looking for does not exist or has been moved.</p>
    <Button Href="" Variant="CBVariantType.Primary" Class="not-found-action" Icon="bi bi-arrow-left">
        Back to Home
    </Button>
</div>

<style>
    .not-found-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: var(--space-20) var(--space-4);
        gap: var(--space-3);
    }

    .not-found-icon {
        color: var(--color-text-muted);
        opacity: 0.5;
        margin-bottom: var(--space-2);
    }

    .not-found-code {
        font-size: 5rem;
        font-weight: 800;
        color: var(--color-text);
        line-height: 1;
        margin: 0;
        letter-spacing: var(--tracking-tight);
        background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .not-found-title {
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
    }

    .not-found-desc {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        max-width: 24rem;
        margin: 0;
    }

    .not-found-action {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        margin-top: var(--space-4);
        padding: var(--space-2) var(--space-5);
        background-color: var(--color-primary);
        color: var(--color-primary-fg);
        border-radius: var(--btn-border-radius);
        font-size: var(--text-sm);
        font-weight: 500;
        text-decoration: none;
        transition: var(--btn-transition);
    }

    .not-found-action:hover {
        background-color: var(--color-primary-hover);
        color: var(--color-primary-fg);
    }
</style>