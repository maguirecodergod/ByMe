@inject LayoutService LayoutService

<div class="sidebar-group @(IsExpanded ? "is-expanded" : "") @(IsActive ? "is-active-group" : "")">
    <div class="sidebar-group-header" @onclick="Toggle">
        <Tooltip Title="@(LayoutService.SidebarType == CSidebarCollapseType.Collapsed ? Item.Title : "")">
            @if (!string.IsNullOrEmpty(Item.Icon))
            {
                <i class="@Item.Icon sidebar-icon"></i>
            }
        </Tooltip>

        @if (LayoutService.SidebarType != CSidebarCollapseType.Collapsed)
        {
            <span class="sidebar-text">@Item.Title</span>
            <i class="bi bi-chevron-right sidebar-chevron"></i>
        }
    </div>

    @if (LayoutService.SidebarType != CSidebarCollapseType.Collapsed)
    {
        <div class="sidebar-group-content">
            @foreach (var child in Item.Children)
            {
                <SidebarItem Item="child" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CNavigationItem Item { get; set; } = default!;

    private bool IsExpanded { get; set; }
    private bool IsActive => Item.Children.Any(c => !string.IsNullOrEmpty(c.Url) && NavigationManager.ToBaseRelativePath(NavigationManager.Uri).StartsWith(c.Url ?? "NONE"));

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private void Toggle()
    {
        if (LayoutService.SidebarType == CSidebarCollapseType.Collapsed) return;
        IsExpanded = !IsExpanded;
    }

    protected override void OnInitialized()
    {
        // Auto expand if active or was expanded
        IsExpanded = IsActive || Item.IsExpanded;
    }
}
